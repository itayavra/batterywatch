msgid "Unpair KDE Connect device"
msgstr "Odpárovat KDE Connect zařízení"

#: ../contents/ui/providers/KDEConnectProvider.qml
msgid "BatteryWatch: KDE Connect daemon unavailable"
msgstr "BatteryWatch: KDE Connect daemon není dostupný"

#: ../contents/ui/providers/KDEConnectProvider.qml
msgid "BatteryWatch: KDE Connect daemon connected"
msgstr "BatteryWatch: KDE Connect daemon připojen"

#. i18n: %1 is the number of devices found.
#: ../contents/ui/providers/OpenLinkHubProvider.qml
msgid "Devices found: %1"
msgstr "Nalezená zařízení: %1"

#. i18n: %1 is the error.
#: ../contents/ui/providers/OpenLinkHubProvider.qml
msgid "Server error: %1"
msgstr "Serverová chyba: %1"

#: ../contents/ui/providers/OpenLinkHubProvider.qml
msgid "Server responded without any battery data!"
msgstr "Server odpověděl bez dat baterie!"

#: ../contents/ui/providers/OpenLinkHubProvider.qml
msgid "Failed to parse battery data:"
msgstr "Nepodařilo se zpracovat data baterie:"

#: ../contents/ui/providers/OpenLinkHubProvider.qml
msgid "Invalid battery data received:"
msgstr "Byla obdržena neplatná data baterie:"

#: ../contents/ui/providers/OpenLinkHubProvider.qml
msgid "Invalid device data for serial:"
msgstr "Neplatná data zařízení pro sériové číslo:"

#: ../contents/ui/providers/OpenLinkHubProvider.qml
msgid "Error processing battery data:"
msgstr "Chyba zpracování dat baterie:"

#: ../contents/ui/providers/OpenLinkHubProvider.qml
msgid "Invalid battery device data, skipping"
msgstr "Neplatná data baterie zařízení, přeskakuji"

#. i18n: %1 is the serial number of the device.
#: ../contents/ui/providers/OpenLinkHubProvider.qml
msgid "Device '%1' is not connected, removing."
msgstr "Zařízení '%1' není připojeno, odstraňuji."

#: ../contents/ui/providers/OpenLinkHubProvider.qml
msgid "Processed devices:"
msgstr "Zpracovaná zařízení:"

#: ../contents/ui/providers/OpenLinkHubProvider.qml
msgid "Invalid device data received for device creation"
msgstr "Byla přijata neplatná data zařízení pro vytvoření záznamu"

#: ../contents/ui/providers/OpenLinkHubProvider.qml
msgid "Invalid battery device data for device creation"
msgstr "Byla přijata neplatná data baterie pro vytvoření záznamu"

#. i18n: %1 is the serial number of the device.
#: ../contents/ui/providers/OpenLinkHubProvider.qml
msgid "Device '%1' is not connected, skipping."
msgstr "Zařízení '%1' není připojeno, přeskakuji."

#. i18n: %1 is the serial number of the device.
#: ../contents/ui/providers/OpenLinkHubProvider.qml
msgid "Fetching device data for serial: %1"
msgstr "Shromažďuji data pro sériové číslo: %1"

#. i18n: %1 is the serial number of the device.
#: ../contents/ui/providers/OpenLinkHubProvider.qml
msgid "Successfully fetched device data for serial: %1"
msgstr "Data úspěšně shromážděna pro zařízení se sériovým číslem: %1"

#: ../contents/ui/providers/OpenLinkHubProvider.qml
msgid "Failed to parse device data:"
msgstr "Nepodařilo se zpracovat data zařízení:"

#. i18n: %1 is the serial number of the device.
#: ../contents/ui/providers/OpenLinkHubProvider.qml
msgid "Server error fetching device '%1':"
msgstr "Chyba serveru při načítání zařízení '%1':"

#: ../contents/ui/providers/OpenRazerProvider.qml
msgid "Unknown Razer Device"
msgstr "Neznámé Razer Zařízení"

#. i18n: Used when a device is known by BatteryWatch to be misreported by UPower.
#. %1 is the device's model name. %2 is the erroneously reported device type (e.g.: ‘mouse’).
#. %3 is the correct device type.
#: ../contents/ui/providers/UPowerProvider.qml
msgid "BatteryWatch: Applying UPower device override for '%1': %2 -> %3"
msgstr "BatteryWatch: Aplikuji přepis UPower zařízení pro '%1': %2 -> %3"
