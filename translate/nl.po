#: ../metadata.desktop
msgid "BatteryWatch"
msgstr "BatteryWatch"

#: ../contents/config/config.qml
msgid "Appearance"
msgstr "Vormgeving"

#: ../contents/config/config.qml
msgid "Integrations"
msgstr "Integraties"

#: ../contents/config/config.qml
msgid "Advanced settings"
msgstr "Geavanceerde instellingen"

#: ../contents/ui/config/AdvancedSettings.qml
msgid "Toggle Debug mode"
msgstr "Foutopsporingsmodus in-/uitschakelen"

#: ../contents/ui/config/Appearance.qml
msgid "System Default (%1)"
msgstr "Systeemstandaard (%1)"

#: ../contents/ui/config/Appearance.qml
msgid "Tray Settings"
msgstr "Systeemvakinstellingen"

#: ../contents/ui/config/Appearance.qml
msgid "Font family:"
msgstr "Lettertype:"

#: ../contents/ui/config/Appearance.qml
msgid "Change the font family used for system tray text."
msgstr "Verander het lettertype voor de systeemvaktekst."

#: ../contents/ui/config/Appearance.qml
msgid "Style"
msgstr "Stijl"

#: ../contents/ui/config/Appearance.qml
msgid "Bold"
msgstr "Vet"

#: ../contents/ui/config/Appearance.qml
msgid ""
"Make the tray text bold.\n"
"Adjust weight between 100 and 1000."
msgstr ""
"Maak de systeemvaktekst vet.\n"
"Pas het gewicht aan tussen 100 en 1000."

#: ../contents/ui/config/Appearance.qml
msgid "Italic"
msgstr "Cursief"

#: ../contents/ui/config/Appearance.qml
msgid "Make the tray text italic."
msgstr "Maak de systeemvaktekst cursief."

#: ../contents/ui/config/Appearance.qml
msgid "Sizes"
msgstr "Groottes"

#: ../contents/ui/config/Appearance.qml
msgid "Font"
msgstr "Tekstgrootte"

#: ../contents/ui/config/Appearance.qml
msgid "Adjust the size of tray text (in pixels)."
msgstr "Pas de grootte van de systeemvaktekst aan (in pixels)."

#: ../contents/ui/config/Appearance.qml
msgid "Icon"
msgstr "Pictogramgrootte"

#: ../contents/ui/config/Appearance.qml
msgid "Adjust the size of tray icons (in pixels)."
msgstr "Pas de grootte van de systeemvakpictogrammen aan (in pixels)."

#: ../contents/ui/config/Appearance.qml
msgid "Spacing"
msgstr "Tussenruimte"

#: ../contents/ui/config/Appearance.qml
msgid "Adjust the gap between tray icons (in pixels)."
msgstr ""
"Pas de ruimte tussen de pictogrammen in het systeemvak aan (in pixels)."

#: ../contents/ui/config/Appearance.qml
msgid "Charging indicator"
msgstr "Laadindicator"

#: ../contents/ui/config/Appearance.qml
msgid "Show charging indicator in tray"
msgstr "Laadindicator weergeven in systeemvak"

#: ../contents/ui/config/Appearance.qml
msgid "Battery Colors"
msgstr "Accukleuren"

#: ../contents/ui/config/Appearance.qml
msgid "Default"
msgstr "Standaard"

#: ../contents/ui/config/Appearance.qml
msgid ""
"Use when no other color state applies. When disabled, system color is used "
"instead."
msgstr ""
"Wordt gebruikt als geen andere kleurstatus van toepassing is. Als "
"uitgeschakeld, wordt de systeemkleur gebruikt."

#: ../contents/ui/config/Appearance.qml
msgid "Charging"
msgstr "Opladen"

#: ../contents/ui/config/Appearance.qml
msgid ""
"Overrides all other colors when device is charging.\n"
"Not all devices are currently supported!"
msgstr ""
"Overschrijft alle andere kleuren wanneer het apparaat oplaadt.\n"
"Niet alle apparaten worden momenteel ondersteund!"

#: ../contents/ui/config/Appearance.qml
msgid "Zone 1"
msgstr "Zone 1"

#: ../contents/ui/config/Appearance.qml
msgid "≤"
msgstr "≤"

#: ../contents/ui/config/Appearance.qml
msgid "%"
msgstr "%"

#: ../contents/ui/config/Appearance.qml
msgid "Applied when battery falls below the set threshold."
msgstr "Wordt toegepast wanneer de accu onder de ingestelde drempel valt"

#: ../contents/ui/config/Appearance.qml
msgid "Zone 2"
msgstr "Zone 2"

#: ../contents/ui/config/Modules.qml
msgid "OpenLinkHub Integration"
msgstr "OpenLinkHub-integratie"

#: ../contents/ui/config/Modules.qml
msgid "Enable: "
msgstr "Inschakelen: "

#: ../contents/ui/config/Modules.qml
msgid "Enabled"
msgstr "Ingeschakeld"

#: ../contents/ui/config/Modules.qml
msgid "Port: "
msgstr "Poort: "

#: ../contents/ui/config/Modules.qml
msgid "OpenRazer Integration"
msgstr "OpenRazer-integratie"

#: ../contents/ui/config/Modules.qml
msgid "Enable"
msgstr "Inschakelen"

#: ../contents/ui/config/Modules.qml
msgid "Polling interval"
msgstr "Verversingsinterval"

#: ../contents/ui/config/Modules.qml
msgid "s"
msgstr "s"

#: ../contents/ui/config/Modules.qml
msgid "KDE Connect Integration"
msgstr "KDE Connect-integratie"

#. i18n: %1 is the version number.
#: ../contents/ui/main.qml
msgid "BatteryWatch v%1"
msgstr "BatteryWatch v%1"

#: ../contents/ui/main.qml
msgid "No connected devices"
msgstr "Er zijn geen apparaten verbonden"

#. i18n: %1 can be the device name or, in the case of multiple batteries, the battery label,
#. or simply the word, ‘Battery’. %2 is the charge percentage value.
#: ../contents/ui/main.qml
msgid "%1: %2%"
msgstr "%1: %2%"

#. i18n: The delimiter when listing multiple batteries in the same device.
#: ../contents/ui/main.qml
msgid ", "
msgstr ", "

#. i18n: Used when there are multiple batteries in a device.
#. %1 is the device name.
#. %2 is the delimited list of the device's batteries and their charge percentages.
#: ../contents/ui/main.qml
msgid "%1 - %2"
msgstr "%1 - %2"

#: ../contents/ui/main.qml
msgid "All devices hidden"
msgstr "Alle apparaten zijn verborgen"

#. i18n: %1 is the charge percentage value; the trailing % is a literal percent sign.
#: ../contents/ui/main.qml
msgid "%1%"
msgstr "%1%"

#: ../contents/ui/main.qml
msgid "Device Battery Levels"
msgstr "Accuniveaus van apparaten"

#: ../contents/ui/main.qml
msgid "Refresh"
msgstr "Herladen"

#: ../contents/ui/main.qml
msgid "Refresh devices"
msgstr "Herlaad de apparatenlijst"

#: ../contents/ui/main.qml ../contents/ui/providers/CompanionProvider.qml
#: ../contents/ui/providers/OpenLinkHubProvider.qml
msgid "Unknown Device"
msgstr "Onbekend apparaat"

#: ../contents/ui/main.qml
msgid "Battery"
msgstr "Accu"

#. i18n: %1 is the battery label or simply the word, ‘Battery’. %2 is the charge percentage value.
#. %3 is a Unicode lightning symbol displayed when the device is charging.
#: ../contents/ui/main.qml
msgid "%1: <span style=\"color:%4\">%2%</span>%3"
msgstr "%1: <span style=\"color:%4\">%2%</span>%3"

#: ../contents/ui/main.qml
msgid "Disconnect"
msgstr "Verbinding verbreken"

#: ../contents/ui/main.qml ../contents/ui/providers/CompanionProvider.qml
#: ../contents/ui/providers/UPowerProvider.qml
msgid "Disconnect device"
msgstr "Verbreek de verbinding met het apparaat"

#: ../contents/ui/main.qml
msgid "Hide"
msgstr "Verbergen"

#: ../contents/ui/main.qml
msgid "Show"
msgstr "Tonen"

#: ../contents/ui/main.qml
msgid "Hide from tray"
msgstr "Verbergen in systeemvak"

#: ../contents/ui/main.qml
msgid "Show in tray"
msgstr "Tonen in systeemvak"

#. i18n: %1 is the charge percentage value, %2 is an optional charging indicator suffix (e.g. " ⚡") or empty string. %% is a literal percent sign.
#: ../contents/ui/main.qml
msgid "%1%%2"
msgstr "%1%%2"

#: ../contents/ui/main.qml
msgid "No connected devices with battery info found"
msgstr "Er zijn verbonden apparaten met accu-informatie aangetroffen"

#: ../contents/ui/providers/CompanionProvider.qml
msgid "BatteryWatch: Companion service disconnected"
msgstr "BatteryWatch: verbinding met hulpdienst verbroken"

#: ../contents/ui/providers/CompanionProvider.qml
msgid "BatteryWatch: Companion service connected"
msgstr "BatteryWatch: verbinding met hulpdienst tot stand gebracht"

#: ../contents/ui/providers/CompanionProvider.qml
msgid "BatteryWatch: Failed to parse companion data:"
msgstr "BatteryWatch: gegevensverwerking van hulpdienst mislukt:"

#: ../contents/ui/providers/KDEConnectProvider.qml
msgid "Unpair KDE Connect device"
msgstr "KDE Connect-apparaat ontkoppelen"

#: ../contents/ui/providers/KDEConnectProvider.qml
msgid "BatteryWatch: KDE Connect daemon unavailable"
msgstr "BatteryWatch: KDE Connect-service niet beschikbaar"

#: ../contents/ui/providers/KDEConnectProvider.qml
msgid "BatteryWatch: KDE Connect daemon connected"
msgstr "BatteryWatch: verbinding met KDE Connect-service tot stand gebracht"

#. i18n: %1 is the number of devices found.
#: ../contents/ui/providers/OpenLinkHubProvider.qml
msgid "Devices found: %1"
msgstr "Aangetroffen apparaten: %1"

#. i18n: %1 is the error.
#: ../contents/ui/providers/OpenLinkHubProvider.qml
msgid "Server error: %1"
msgstr "Serverfout: %1"

#: ../contents/ui/providers/OpenLinkHubProvider.qml
msgid "Server responded without any battery data!"
msgstr "De server gaf geen accu-informatie!"

#: ../contents/ui/providers/OpenLinkHubProvider.qml
msgid "Failed to parse battery data:"
msgstr "De accu-informatie kan niet worden verwerkt:"

#: ../contents/ui/providers/OpenLinkHubProvider.qml
msgid "Invalid battery data received:"
msgstr "Ongeldige accu-informatie ontvangen:"

#: ../contents/ui/providers/OpenLinkHubProvider.qml
msgid "Invalid device data for serial:"
msgstr "Ongeldige accu-informatie van serienummer:"

#: ../contents/ui/providers/OpenLinkHubProvider.qml
msgid "Error processing battery data:"
msgstr "De accu-informatie kan niet worden verwerkt:"

#: ../contents/ui/providers/OpenLinkHubProvider.qml
msgid "Invalid battery device data, skipping"
msgstr "Ongeldige accu-informatie: overslaan van"

#. i18n: %1 is the serial number of the device.
#: ../contents/ui/providers/OpenLinkHubProvider.qml
msgid "Device '%1' is not connected, removing."
msgstr "'%1' is niet verbonden en wordt daarom verwijderd."

#: ../contents/ui/providers/OpenLinkHubProvider.qml
msgid "Processed devices:"
msgstr "Verwerkte apparaten:"

#: ../contents/ui/providers/OpenLinkHubProvider.qml
msgid "Invalid device data received for device creation"
msgstr "Ongeldige apparaatinformatie ontvangen"

#: ../contents/ui/providers/OpenLinkHubProvider.qml
msgid "Invalid battery device data for device creation"
msgstr "Ongeldige accu-informatie ontvangen"

#. i18n: %1 is the serial number of the device.
#: ../contents/ui/providers/OpenLinkHubProvider.qml
msgid "Device '%1' is not connected, skipping."
msgstr "'%1' is niet verbonden en wordt daarom overgeslagen."

#. i18n: %1 is the serial number of the device.
#: ../contents/ui/providers/OpenLinkHubProvider.qml
msgid "Fetching device data for serial: %1"
msgstr "Bezig met ophalen van apparaatinformatie voor %1"

#. i18n: %1 is the serial number of the device.
#: ../contents/ui/providers/OpenLinkHubProvider.qml
msgid "Successfully fetched device data for serial: %1"
msgstr "De apparaatinformatie van serienummer %1 is opgehaald"

#: ../contents/ui/providers/OpenLinkHubProvider.qml
msgid "Failed to parse device data:"
msgstr "De apparaatinformatie kan niet worden verwerkt:"

#. i18n: %1 is the serial number of the device.
#: ../contents/ui/providers/OpenLinkHubProvider.qml
msgid "Server error fetching device '%1':"
msgstr "Er is een serverfout opgetreden tijdens het ophalen van '%1':"

#: ../contents/ui/providers/OpenRazerProvider.qml
msgid "Unknown Razer Device"
msgstr "Onbekend Razer-apparaat"

#. i18n: Used when a device is known by BatteryWatch to be misreported by UPower.
#. %1 is the device's model name. %2 is the erroneously reported device type (e.g.: ‘mouse’).
#. %3 is the correct device type.
#: ../contents/ui/providers/UPowerProvider.qml
msgid "BatteryWatch: Applying UPower device override for '%1': %2 -> %3"
msgstr ""
"BatteryWatch: er wordt een UPower-voorrangsregel ingesteld voor '%1': %2 → %3"
