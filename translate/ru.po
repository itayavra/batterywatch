#: ../metadata.desktop
msgid "BatteryWatch"
msgstr "BatteryWatch"

#: ../contents/config/config.qml
msgid "Appearance"
msgstr "Оформление"

#: ../contents/config/config.qml
msgid "Integrations"
msgstr "Интеграции"

#: ../contents/config/config.qml
msgid "Advanced settings"
msgstr "Продвинутые настройки"

#: ../contents/ui/config/AdvancedSettings.qml
msgid "Toggle Debug mode"
msgstr "Включить режим отладки"

#: ../contents/ui/config/Appearance.qml
msgid "System Default (%1)"
msgstr "По умолчанию (%1)"

#: ../contents/ui/config/Appearance.qml
msgid "Tray Settings"
msgstr "Настройки системного лотка"

#: ../contents/ui/config/Appearance.qml
msgid "Font family:"
msgstr "Семейство шрифтов:"

#: ../contents/ui/config/Appearance.qml
msgid "Change the font family used for system tray text."
msgstr "Изменить семейство шрифтов, используемое для текста в системном лотке."

#: ../contents/ui/config/Appearance.qml
msgid "Style"
msgstr "Стиль"

#: ../contents/ui/config/Appearance.qml
msgid "Bold"
msgstr "Жирный"

#: ../contents/ui/config/Appearance.qml
msgid ""
"Make the tray text bold.\n"
"Adjust weight between 100 and 1000."
msgstr ""
"Использовать жирный шрифт для текста в системном лотке.\n"
"Толщина шрифта: от 100 до 1000."

#: ../contents/ui/config/Appearance.qml
msgid "Italic"
msgstr "Курсив"

#: ../contents/ui/config/Appearance.qml
msgid "Make the tray text italic."
msgstr "Использовать курсив для текста в системном лотке."

#: ../contents/ui/config/Appearance.qml
msgid "Sizes"
msgstr "Размеры"

#: ../contents/ui/config/Appearance.qml
msgid "Font"
msgstr "Шрифт"

#: ../contents/ui/config/Appearance.qml
msgid "Adjust the size of tray text (in pixels)."
msgstr "Изменить размер текста в системном лотке (в пикселях)."

#: ../contents/ui/config/Appearance.qml
msgid "Icon"
msgstr "Значок"

#: ../contents/ui/config/Appearance.qml
msgid "Adjust the size of tray icons (in pixels)."
msgstr "Изменить размер значков в системном лотке (в пикселях)."

#: ../contents/ui/config/Appearance.qml
msgid "Spacing"
msgstr ""

#: ../contents/ui/config/Appearance.qml
msgid "Adjust the gap between tray icons (in pixels)."
msgstr ""

#: ../contents/ui/config/Appearance.qml
msgid "Charging indicator"
msgstr "Индикатор зарядки"

#: ../contents/ui/config/Appearance.qml
msgid "Show charging indicator in tray"
msgstr "Показывать индикатор зарядки в системном лотке"

#: ../contents/ui/config/Appearance.qml
msgid "Battery Colors"
msgstr "Цвета батареи"

#: ../contents/ui/config/Appearance.qml
msgid "Default"
msgstr "По умолчанию"

#: ../contents/ui/config/Appearance.qml
msgid "Use when no other color state applies. When disabled, system color is used instead."
msgstr ""
"Используется, когда другие цветовые состояния не применяются.\n"
"Если отключено, будет использоваться системный цвет."

#: ../contents/ui/config/Appearance.qml
msgid "Charging"
msgstr "Зарядка"

#: ../contents/ui/config/Appearance.qml
msgid ""
"Overrides all other colors when device is charging.\n"
"Not all devices are currently supported!"
msgstr ""
"Переопределяет все остальные цвета во время зарядки устройства.\n"
"Поддерживаются не все устройства!"

#: ../contents/ui/config/Appearance.qml
msgid "Zone 1"
msgstr "Зона 1"

#: ../contents/ui/config/Appearance.qml
msgid "≤"
msgstr "≤"

#: ../contents/ui/config/Appearance.qml
msgid "%"
msgstr "%"

#: ../contents/ui/config/Appearance.qml
msgid "Applied when battery falls below the set threshold."
msgstr "Применяется, когда заряд батареи опускается ниже заданного порога."

#: ../contents/ui/config/Appearance.qml
msgid "Zone 2"
msgstr "Зона 2"

#: ../contents/ui/config/Modules.qml
msgid "OpenLinkHub Integration"
msgstr "Интеграция с OpenLinkHub"

#: ../contents/ui/config/Modules.qml
msgid "Enable: "
msgstr "Включить: "

#: ../contents/ui/config/Modules.qml
msgid "Enabled"
msgstr "Включено"

#: ../contents/ui/config/Modules.qml
msgid "Port: "
msgstr "Порт: "

#: ../contents/ui/config/Modules.qml
msgid "OpenRazer Integration"
msgstr "Интеграция с OpenRazer"

#: ../contents/ui/config/Modules.qml
msgid "Enable"
msgstr "Включить"

#: ../contents/ui/config/Modules.qml
msgid "Polling interval"
msgstr "Интервал опроса"

#: ../contents/ui/config/Modules.qml
msgid "s"
msgstr "с"

#: ../contents/ui/config/Modules.qml
msgid "KDE Connect Integration"
msgstr "Интеграция с KDE Connect"

#. i18n: %1 is the version number.
#: ../contents/ui/main.qml
msgid "BatteryWatch v%1"
msgstr "BatteryWatch v%1"

#: ../contents/ui/main.qml
msgid "No connected devices"
msgstr "Нет подключённых устройств"

#. i18n: %1 can be the device name or, in the case of multiple batteries, the battery label,
#. or simply the word, ‘Battery’. %2 is the charge percentage value.
#: ../contents/ui/main.qml
msgid "%1: %2%"
msgstr "%1: %2%"

#. i18n: The delimiter when listing multiple batteries in the same device.
#: ../contents/ui/main.qml
msgid ", "
msgstr ", "

#. i18n: Used when there are multiple batteries in a device.
#. %1 is the device name.
#. %2 is the delimited list of the device's batteries and their charge percentages.
#: ../contents/ui/main.qml
msgid "%1 - %2"
msgstr "%1 — %2"

#: ../contents/ui/main.qml
msgid "All devices hidden"
msgstr "Все устройства скрыты"

#. i18n: %1 is the charge percentage value; the trailing % is a literal percent sign.
#: ../contents/ui/main.qml
msgid "%1%"
msgstr ""

#: ../contents/ui/main.qml
msgid "Device Battery Levels"
msgstr "Уровень заряда устройств"

#: ../contents/ui/main.qml
msgid "Refresh"
msgstr "Обновить"

#: ../contents/ui/main.qml
msgid "Refresh devices"
msgstr "Обновить устройства"

#: ../contents/ui/main.qml ../contents/ui/providers/CompanionProvider.qml ../contents/ui/providers/OpenLinkHubProvider.qml
msgid "Unknown Device"
msgstr "Неизвестное устройство"

#: ../contents/ui/main.qml
msgid "Battery"
msgstr "Батарея"

#. i18n: %1 is the battery label or simply the word, ‘Battery’. %2 is the charge percentage value.
#. %3 is a Unicode lightning symbol displayed when the device is charging.
#: ../contents/ui/main.qml
msgid "%1: <span style=\"color:%4\">%2%</span>%3"
msgstr "%1: <span style=\"color:%4\">%2%</span>%3"

#: ../contents/ui/main.qml
msgid "Disconnect"
msgstr "Отключить"

#: ../contents/ui/main.qml ../contents/ui/providers/CompanionProvider.qml ../contents/ui/providers/UPowerProvider.qml
msgid "Disconnect device"
msgstr "Отключить устройство"

#: ../contents/ui/main.qml
msgid "Hide"
msgstr "Скрыть"

#: ../contents/ui/main.qml
msgid "Show"
msgstr "Показать"

#: ../contents/ui/main.qml
msgid "Hide from tray"
msgstr "Скрыть из системного лотка"

#: ../contents/ui/main.qml
msgid "Show in tray"
msgstr "Показать в системном лотке"

#. i18n: %1 is the charge percentage value, %2 is an optional charging indicator suffix (e.g. " ⚡") or empty string. %% is a literal percent sign.
#: ../contents/ui/main.qml
msgid "%1%%2"
msgstr "%1%%2"

#: ../contents/ui/main.qml
msgid "No connected devices with battery info found"
msgstr "Не найдено подключённых устройств с информацией о батарее"

#: ../contents/ui/providers/CompanionProvider.qml
msgid "BatteryWatch: Companion service disconnected"
msgstr "BatteryWatch: служба компаньона отключена"

#: ../contents/ui/providers/CompanionProvider.qml
msgid "BatteryWatch: Companion service connected"
msgstr "BatteryWatch: служба компаньона подключена"

#: ../contents/ui/providers/CompanionProvider.qml
msgid "BatteryWatch: Failed to parse companion data:"
msgstr "BatteryWatch: не удалось обработать данные компаньона:"

#: ../contents/ui/providers/KDEConnectProvider.qml
msgid "Unpair KDE Connect device"
msgstr "Отвязать устройство KDE Connect"

#: ../contents/ui/providers/KDEConnectProvider.qml
msgid "BatteryWatch: KDE Connect daemon unavailable"
msgstr "BatteryWatch: служба KDE Connect недоступна"

#: ../contents/ui/providers/KDEConnectProvider.qml
msgid "BatteryWatch: KDE Connect daemon connected"
msgstr "BatteryWatch: служба KDE Connect подключена"

#. i18n: %1 is the number of devices found.
#: ../contents/ui/providers/OpenLinkHubProvider.qml
msgid "Devices found: %1"
msgstr "Найдено устройств: %1"

#. i18n: %1 is the error.
#: ../contents/ui/providers/OpenLinkHubProvider.qml
msgid "Server error: %1"
msgstr "Ошибка сервера: %1"

#: ../contents/ui/providers/OpenLinkHubProvider.qml
msgid "Server responded without any battery data!"
msgstr "Сервер ответил без данных о батарее!"

#: ../contents/ui/providers/OpenLinkHubProvider.qml
msgid "Failed to parse battery data:"
msgstr "Не удалось обработать данные батареи:"

#: ../contents/ui/providers/OpenLinkHubProvider.qml
msgid "Invalid battery data received:"
msgstr "Получены некорректные данные батареи:"

#: ../contents/ui/providers/OpenLinkHubProvider.qml
msgid "Invalid device data for serial:"
msgstr "Некорректные данные устройства для серийного номера:"

#: ../contents/ui/providers/OpenLinkHubProvider.qml
msgid "Error processing battery data:"
msgstr "Ошибка обработки данных батареи:"

#: ../contents/ui/providers/OpenLinkHubProvider.qml
msgid "Invalid battery device data, skipping"
msgstr "Некорректные данные батареи устройства, пропуск"

#. i18n: %1 is the serial number of the device.
#: ../contents/ui/providers/OpenLinkHubProvider.qml
msgid "Device '%1' is not connected, removing."
msgstr "Устройство «%1» не подключено, удаление."

#: ../contents/ui/providers/OpenLinkHubProvider.qml
msgid "Processed devices:"
msgstr "Обработанные устройства:"

#: ../contents/ui/providers/OpenLinkHubProvider.qml
msgid "Invalid device data received for device creation"
msgstr "Получены некорректные данные для создания устройства"

#: ../contents/ui/providers/OpenLinkHubProvider.qml
msgid "Invalid battery device data for device creation"
msgstr "Получены некорректные данные батареи для создания устройства"

#. i18n: %1 is the serial number of the device.
#: ../contents/ui/providers/OpenLinkHubProvider.qml
msgid "Device '%1' is not connected, skipping."
msgstr "Устройство «%1» не подключено, пропуск."

#. i18n: %1 is the serial number of the device.
#: ../contents/ui/providers/OpenLinkHubProvider.qml
msgid "Fetching device data for serial: %1"
msgstr "Получение данных устройства для серийного номера: %1"

#. i18n: %1 is the serial number of the device.
#: ../contents/ui/providers/OpenLinkHubProvider.qml
msgid "Successfully fetched device data for serial: %1"
msgstr "Данные устройства для серийного номера %1 успешно получены"

#: ../contents/ui/providers/OpenLinkHubProvider.qml
msgid "Failed to parse device data:"
msgstr "Не удалось обработать данные устройства:"

#. i18n: %1 is the serial number of the device.
#: ../contents/ui/providers/OpenLinkHubProvider.qml
msgid "Server error fetching device '%1':"
msgstr "Ошибка сервера при получении устройства «%1»:"

#: ../contents/ui/providers/OpenRazerProvider.qml
msgid "Unknown Razer Device"
msgstr "Неизвестное устройство Razer"

#. i18n: Used when a device is known by BatteryWatch to be misreported by UPower.
#. %1 is the device's model name. %2 is the erroneously reported device type (e.g.: ‘mouse’).
#. %3 is the correct device type.
#: ../contents/ui/providers/UPowerProvider.qml
msgid "BatteryWatch: Applying UPower device override for '%1': %2 -> %3"
msgstr "BatteryWatch: применяется переопределение устройства UPower для «%1»: %2 -> %3"
