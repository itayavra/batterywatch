#: ../metadata.desktop
msgid "BatteryWatch"
msgstr "BatteryWatch"

#: ../contents/config/config.qml
msgid "Appearance"
msgstr "Megjelenés"

#: ../contents/config/config.qml
msgid "Integrations"
msgstr "Integrációk"

#: ../contents/config/config.qml
msgid "Advanced settings"
msgstr "Speciális beállítások"

#: ../contents/ui/config/AdvancedSettings.qml
msgid "Toggle Debug mode"
msgstr "Hibakeresési mód be-/kikapcsolása"

#: ../contents/ui/config/Appearance.qml
msgid "System Default (%1)"
msgstr "Rendszer alapértelmezése (%1)"

#: ../contents/ui/config/Appearance.qml
msgid "Tray Settings"
msgstr "Tálca beállításai"

#: ../contents/ui/config/Appearance.qml
msgid "Font family:"
msgstr "Betűcsalád:"

#: ../contents/ui/config/Appearance.qml
msgid "Change the font family used for system tray text."
msgstr "A rendszertálca szövegéhez használt betűcsalád megváltoztatása."

#: ../contents/ui/config/Appearance.qml
msgid "Style"
msgstr "Stílus"

#: ../contents/ui/config/Appearance.qml
msgid "Bold"
msgstr "Félkövér"

#: ../contents/ui/config/Appearance.qml
msgid ""
"Make the tray text bold.\n"
"Adjust weight between 100 and 1000."
msgstr ""
"A tálcaszöveg félkövér megjelenítése.\n"
"A vastagság 100 és 1000 között állítható be."

#: ../contents/ui/config/Appearance.qml
msgid "Italic"
msgstr "Dőlt"

#: ../contents/ui/config/Appearance.qml
msgid "Make the tray text italic."
msgstr "A tálcaszöveg dőlt megjelenítése."

#: ../contents/ui/config/Appearance.qml
msgid "Sizes"
msgstr "Méretek"

#: ../contents/ui/config/Appearance.qml
msgid "Font"
msgstr "Betűméret"

#: ../contents/ui/config/Appearance.qml
msgid "Adjust the size of tray text (in pixels)."
msgstr "A tálcaszöveg méretének beállítása (képpontokban)."

#: ../contents/ui/config/Appearance.qml
msgid "Icon"
msgstr "Ikon"

#: ../contents/ui/config/Appearance.qml
msgid "Adjust the size of tray icons (in pixels)."
msgstr "A tálcaikonok méretének beállítása (képpontokban)."

#: ../contents/ui/config/Appearance.qml
msgid "Spacing"
msgstr "Térköz"

#: ../contents/ui/config/Appearance.qml
msgid "Adjust the gap between tray icons (in pixels)."
msgstr "A tálcaikonok közötti távolság beállítása (képpontban)."

#: ../contents/ui/config/Appearance.qml
msgid "Charging indicator"
msgstr "Töltésjelző"

#: ../contents/ui/config/Appearance.qml
msgid "Show charging indicator in tray"
msgstr "Töltésjelző megjelenítése a tálcán"

#: ../contents/ui/config/Appearance.qml
msgid "Battery Colors"
msgstr "Akkumulátorszínek"

#: ../contents/ui/config/Appearance.qml
msgid "Default"
msgstr "Alapértelmezett"

#: ../contents/ui/config/Appearance.qml
msgid ""
"Use when no other color state applies. When disabled, system color is used "
"instead."
msgstr ""
"Ha más szín állapot nem érvényes. Kikapcsolt állapotban a rendszerszín kerül "
"alkalmazásra."

#: ../contents/ui/config/Appearance.qml
msgid "Charging"
msgstr "Töltés"

#: ../contents/ui/config/Appearance.qml
msgid ""
"Overrides all other colors when device is charging.\n"
"Not all devices are currently supported!"
msgstr ""
"Felülbírálja az összes többi színt töltés közben.\n"
"Jelenleg nem minden eszköz támogatott!"

#: ../contents/ui/config/Appearance.qml
msgid "Zone 1"
msgstr "1. zóna"

#: ../contents/ui/config/Appearance.qml
msgid "≤"
msgstr "≤"

#: ../contents/ui/config/Appearance.qml
msgid "%"
msgstr "%"

#: ../contents/ui/config/Appearance.qml
msgid "Applied when battery falls below the set threshold."
msgstr "Alkalmazva, ha az akkumulátor szintje a beállított küszöb alá esik."

#: ../contents/ui/config/Appearance.qml
msgid "Zone 2"
msgstr "2. zóna"

#: ../contents/ui/config/Modules.qml
msgid "OpenLinkHub Integration"
msgstr "OpenLinkHub-integráció"

#: ../contents/ui/config/Modules.qml
msgid "Enable: "
msgstr "Engedélyezés: "

#: ../contents/ui/config/Modules.qml
msgid "Enabled"
msgstr "Engedélyezve"

#: ../contents/ui/config/Modules.qml
msgid "Port: "
msgstr "Port: "

#: ../contents/ui/config/Modules.qml
msgid "OpenRazer Integration"
msgstr "OpenRazer-integráció"

#: ../contents/ui/config/Modules.qml
msgid "Enable"
msgstr "Engedélyezés"

#: ../contents/ui/config/Modules.qml
msgid "Polling interval"
msgstr "Lekérdezési időköz"

#: ../contents/ui/config/Modules.qml
msgid "s"
msgstr "mp"

#: ../contents/ui/config/Modules.qml
msgid "KDE Connect Integration"
msgstr "KDE Connect-integráció"

#. i18n: %1 is the version number.
#: ../contents/ui/main.qml
msgid "BatteryWatch v%1"
msgstr "BatteryWatch v%1"

#: ../contents/ui/main.qml
msgid "No connected devices"
msgstr "Nincsenek csatlakoztatott eszközök"

#. i18n: %1 can be the device name or, in the case of multiple batteries, the battery label,
#. or simply the word, ‘Battery’. %2 is the charge percentage value.
#: ../contents/ui/main.qml
msgid "%1: %2%"
msgstr "%1: %2%"

#. i18n: The delimiter when listing multiple batteries in the same device.
#: ../contents/ui/main.qml
msgid ", "
msgstr ", "

#. i18n: Used when there are multiple batteries in a device.
#. %1 is the device name.
#. %2 is the delimited list of the device's batteries and their charge percentages.
#: ../contents/ui/main.qml
msgid "%1 - %2"
msgstr "%1 - %2"

#: ../contents/ui/main.qml
msgid "All devices hidden"
msgstr "Minden eszköz rejtett"

#. i18n: %1 is the charge percentage value. %% is a literal percent sign.
#: ../contents/ui/main.qml
msgid "%1%"
msgstr "%1%"

#: ../contents/ui/main.qml
msgid "Device Battery Levels"
msgstr "Eszközök töltöttsége"

#: ../contents/ui/main.qml
msgid "Refresh"
msgstr "Frissítés"

#: ../contents/ui/main.qml
msgid "Refresh devices"
msgstr "Eszközlista frissítése"

#: ../contents/ui/main.qml ../contents/ui/providers/CompanionProvider.qml
#: ../contents/ui/providers/OpenLinkHubProvider.qml
msgid "Unknown Device"
msgstr "Ismeretlen eszköz"

#: ../contents/ui/main.qml
msgid "Battery"
msgstr "Akkumulátor"

#. i18n: %1 is the battery label or simply the word, ‘Battery’. %2 is the charge percentage value.
#. %3 is a Unicode lightning symbol displayed when the device is charging.
#: ../contents/ui/main.qml
msgid "%1: <span style=\"color:%4\">%2%</span>%3"
msgstr "%1: <span style=\"color:%4\">%2%</span>%3"

#: ../contents/ui/main.qml
msgid "Disconnect"
msgstr "Leválasztás"

#: ../contents/ui/main.qml ../contents/ui/providers/CompanionProvider.qml
#: ../contents/ui/providers/UPowerProvider.qml
msgid "Disconnect device"
msgstr "Eszköz leválasztása"

#: ../contents/ui/main.qml
msgid "Hide"
msgstr "Elrejtés"

#: ../contents/ui/main.qml
msgid "Show"
msgstr "Megjelenítés"

#: ../contents/ui/main.qml
msgid "Hide from tray"
msgstr "Elrejtés a paneltálcáról"

#: ../contents/ui/main.qml
msgid "Show in tray"
msgstr "Megjelenítés a paneltálcán"

#. i18n: %1 is the charge percentage value, %2 is an optional charging indicator suffix (e.g. " ⚡") or empty string. %% is a literal percent sign.
#: ../contents/ui/main.qml
msgid "%1%%2"
msgstr "%1%%2"

#: ../contents/ui/main.qml
msgid "No connected devices with battery info found"
msgstr ""
"Jelenleg egy csatlakoztatott eszköz sem közöl akkumulátor-töltöttségi "
"adatokat"

#: ../contents/ui/providers/CompanionProvider.qml
msgid "BatteryWatch: Companion service disconnected"
msgstr "BatteryWatch: Megszakadt a kapcsolat a társszolgáltatással"

#: ../contents/ui/providers/CompanionProvider.qml
msgid "BatteryWatch: Companion service connected"
msgstr "BatteryWatch: A társszolgáltatás csatlakoztatva van"

#: ../contents/ui/providers/CompanionProvider.qml
msgid "BatteryWatch: Failed to parse companion data:"
msgstr "A társadatok feldolgozása meghiúsult:"

#: ../contents/ui/providers/KDEConnectProvider.qml
msgid "Unpair KDE Connect device"
msgstr "KDE Connect-eszköz párosításának megszüntetése"

#: ../contents/ui/providers/KDEConnectProvider.qml
msgid "BatteryWatch: KDE Connect daemon unavailable"
msgstr "BatteryWatch: A KDE Connect-szolgáltatás nem érhető el"

#: ../contents/ui/providers/KDEConnectProvider.qml
msgid "BatteryWatch: KDE Connect daemon connected"
msgstr "BatteryWatch: A KDE Connect-szolgáltatás csatlakoztatva van"

#. i18n: %1 is the number of devices found.
#: ../contents/ui/providers/OpenLinkHubProvider.qml
msgid "Devices found: %1"
msgstr "%1 eszköz észlelve."

#. i18n: %1 is the error.
#: ../contents/ui/providers/OpenLinkHubProvider.qml
msgid "Server error: %1"
msgstr "Kiszolgálóhiba: %1"

#: ../contents/ui/providers/OpenLinkHubProvider.qml
msgid "Server responded without any battery data!"
msgstr "A kiszolgáló válasza nem tartalmazott akkumulátor-adatokat!"

#: ../contents/ui/providers/OpenLinkHubProvider.qml
msgid "Failed to parse battery data:"
msgstr "Az akkumulátor-adatok feldolgozása meghiúsult:"

#: ../contents/ui/providers/OpenLinkHubProvider.qml
msgid "Invalid battery data received:"
msgstr "A fogadott akkumulátor-adatok érvénytelenek:"

#: ../contents/ui/providers/OpenLinkHubProvider.qml
msgid "Invalid device data for serial:"
msgstr "A következő szériaszámú eszköz adatai érvénytelenek:"

#: ../contents/ui/providers/OpenLinkHubProvider.qml
msgid "Error processing battery data:"
msgstr "Az akkumulátor-adatok feldolgozása meghiúsult:"

#: ../contents/ui/providers/OpenLinkHubProvider.qml
msgid "Invalid battery device data, skipping"
msgstr "Az eszköz akkumulátor-adatai helytelenek. Kihagyás."

#. i18n: %1 is the serial number of the device.
#: ../contents/ui/providers/OpenLinkHubProvider.qml
msgid "Device '%1' is not connected, removing."
msgstr "A(z) „%1” eszköz nincs csatlakoztatva. Eltávolítás."

#: ../contents/ui/providers/OpenLinkHubProvider.qml
msgid "Processed devices:"
msgstr "Feldolgozott eszközök:"

#: ../contents/ui/providers/OpenLinkHubProvider.qml
msgid "Invalid device data received for device creation"
msgstr ""
"Az eszköz létrehozása meghiúsult, mivel a fogadott adatok érvénytelenek"

#: ../contents/ui/providers/OpenLinkHubProvider.qml
msgid "Invalid battery device data for device creation"
msgstr ""
"Az eszköz létrehozása meghiúsult, mivel a fogadott akkumulátor-adatok "
"érvénytelenek"

#. i18n: %1 is the serial number of the device.
#: ../contents/ui/providers/OpenLinkHubProvider.qml
msgid "Device '%1' is not connected, skipping."
msgstr "A(z) „%1” eszköz nincs csatlakoztatva. Kihagyás."

#. i18n: %1 is the serial number of the device.
#: ../contents/ui/providers/OpenLinkHubProvider.qml
msgid "Fetching device data for serial: %1"
msgstr "A(z) „%1” szériaszámú eszköz adatainak lekérése."

#. i18n: %1 is the serial number of the device.
#: ../contents/ui/providers/OpenLinkHubProvider.qml
msgid "Successfully fetched device data for serial: %1"
msgstr "A(z) „%1” szériaszámú eszköz adatainak lekérése sikeresen megtörtént."

#: ../contents/ui/providers/OpenLinkHubProvider.qml
msgid "Failed to parse device data:"
msgstr "Az eszköz adatainak feldolgozása meghiúsult:"

#. i18n: %1 is the serial number of the device.
#: ../contents/ui/providers/OpenLinkHubProvider.qml
msgid "Server error fetching device '%1':"
msgstr "A(z) „%1” eszköz adatainak lekérése közben kiszolgálóhiba történt:"

#: ../contents/ui/providers/OpenRazerProvider.qml
msgid "Unknown Razer Device"
msgstr "Ismeretlen Razer-eszköz"

#. i18n: Used when a device is known by BatteryWatch to be misreported by UPower.
#. %1 is the device's model name. %2 is the erroneously reported device type (e.g.: ‘mouse’).
#. %3 is the correct device type.
#: ../contents/ui/providers/UPowerProvider.qml
msgid "BatteryWatch: Applying UPower device override for '%1': %2 -> %3"
msgstr "BatteryWatch: UPower-eszköz felülírása. „%1”: %2 -> %3"
